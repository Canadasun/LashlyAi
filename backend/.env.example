# Server
PORT=3000
NODE_ENV=development
# Base URL used to build authenticated /media URLs
PUBLIC_BASE_URL=http://localhost:3000

# Signs session tokens (backend/src/services/auth.service.ts). REQUIRED in every
# environment. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Without it, dev/test falls back to a hardcoded secret; production/staging refuse to
# start rather than use it silently.
AUTH_SESSION_SECRET=

# Database
DATABASE_URL=postgres://localhost:5432/lashlyai_dev

# OpenAI
OPENAI_API_KEY=

# Private S3-compatible image storage. Required in staging and production. Railway
# bucket credentials map directly to these variables.
AWS_ENDPOINT_URL=
AWS_DEFAULT_REGION=
AWS_S3_BUCKET_NAME=
AWS_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# Apple StoreKit (subscription receipt verification)
APPLE_SHARED_SECRET=

# Admin dashboard (HTTP Basic Auth password) — leave blank to disable /admin entirely
ADMIN_API_KEY=

# Comma-separated allowlist of emails granted is_admin (real per-user access: grant
# comp subscriptions, etc.) on their next authenticated request — see
# syncAdminFlagFromAllowlist in models/User.ts. Distinct from ADMIN_API_KEY above.
ADMIN_EMAILS=

# Free-tier plan limits (5 clients, 5 coach Q/day, 3 eye scans/month) — usage is always
# tracked, but only actually blocks requests when this is "true". Leave unset/false
# during testing so every tier is free/unlimited, per owner instruction.
ENFORCE_PLAN_LIMITS=
