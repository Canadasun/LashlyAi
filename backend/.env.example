# Server
PORT=3000
NODE_ENV=development
# Base URL used to build public image URLs for the local-disk storage stub
PUBLIC_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://localhost:5432/lashlyai_dev

# OpenAI
OPENAI_API_KEY=

# AWS S3 (image storage) — leave blank to use local-disk storage stub in dev
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Firebase Admin (auth verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Apple StoreKit (subscription receipt verification)
APPLE_SHARED_SECRET=
