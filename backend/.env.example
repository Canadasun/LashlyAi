# Server
PORT=3000
NODE_ENV=development
# Base URL used to build authenticated /media URLs
PUBLIC_BASE_URL=http://localhost:3000

# Signs session tokens (backend/src/services/auth.service.ts). REQUIRED in every
# environment. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Without it, dev/test falls back to a hardcoded secret; production/staging refuse to
# start rather than use it silently.
AUTH_SESSION_SECRET=

# Database
DATABASE_URL=postgres://localhost:5432/lashlyai_dev

# OpenAI
OPENAI_API_KEY=

# Private S3-compatible image storage. Required in staging and production. Railway
# bucket credentials map directly to these variables.
AWS_ENDPOINT_URL=
AWS_DEFAULT_REGION=
AWS_S3_BUCKET_NAME=
AWS_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# Apple StoreKit (subscription receipt verification)
APPLE_SHARED_SECRET=

# Legacy — the admin dashboard used to be gated by this shared secret; it's now
# gated by a real admin account's own login (see requireAdminAccount.ts). Only
# kept as an emergency fallback session-signing secret (auth.service.ts) if
# AUTH_SESSION_SECRET is somehow unset. Safe to leave blank.
ADMIN_API_KEY=

# Comma-separated allowlist of emails granted is_admin (real per-user access: gate
# the admin dashboard, grant comp subscriptions, etc.) on their next authenticated
# request — see syncAdminFlagFromAllowlist in models/User.ts. That account also
# needs an actual login password — see backend/src/scripts/seedAdmin.ts.
ADMIN_EMAILS=

# Free-tier plan limits (client profiles, coach questions, eye scans, photo
# feedback, lash map generation, retention checks, forum posts, marketing AI —
# see planLimits.service.ts FREE_LIMITS) — usage is always tracked, but only
# actually blocks requests when this is "true". Per owner instruction ("gate all
# tiers"), set this to "true" once deployed and verified end-to-end.
ENFORCE_PLAN_LIMITS=

# Transactional email (backend/src/services/email.service.ts) via Resend's HTTP API.
# Without RESEND_API_KEY, emails are logged, not delivered — safe to leave blank in
# dev/test. EMAIL_FROM_ADDRESS's domain must be verified with Resend before real
# delivery works.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=LashlyAI <support@lashlyai.com>

# SMS alerts (backend/src/services/sms.service.ts) via Twilio's REST API. Without all
# three set, SMS alerts are logged, not delivered — safe to leave blank in dev/test.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Where operational alerts go (new forum reports, unhandled server errors — see
# notificationTemplates.ts). Email defaults to support@lashlyai.com if unset; the phone
# number is optional and SMS alerts are simply skipped without it.
ADMIN_ALERT_EMAIL=
ADMIN_ALERT_PHONE_NUMBER=
